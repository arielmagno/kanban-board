# Copy this file to .env and fill in the values
# cp .env.example .env

# JWT secrets — change these in production!
JWT_SECRET=boardflow-dev-secret-change-in-prod
JWT_REFRESH_SECRET=boardflow-refresh-secret-change-in-prod

# API URL (used by the web app in the browser)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Internal API URL (used by Next.js server components inside Docker)
INTERNAL_API_URL=http://api:4000
