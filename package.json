{
  "name": "kanban-board",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/web\"",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspace=apps/api",
    "postinstall": "npm run build --workspace=packages/shared && cd apps/api && npx prisma generate"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
